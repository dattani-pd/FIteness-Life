<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document
    type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB"
    version="3.0"
    toolsVersion="18122"
    targetRuntime="iOS.CocoaTouch"
    propertyAccessControl="none"
    useAutolayout="YES"
    launchScreen="YES"
    colorMatched="YES"
    initialViewController="vc">

    <device id="retina6_12" orientation="portrait" appearance="light"/>

    <scenes>
        <!-- Launch Screen -->
        <scene sceneID="scene">
            <objects>

                <viewController id="vc" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="mainView">

                        <!-- White Background -->
                        <color key="backgroundColor"
                            red="1" green="1" blue="1" alpha="1"
                            colorSpace="custom" customColorSpace="sRGB"/>

                        <subviews>
                            <imageView
                                clipsSubviews="YES"
                                userInteractionEnabled="NO"
                                contentMode="scaleAspectFit"
                                image="LaunchImage"
                                translatesAutoresizingMaskIntoConstraints="NO"
                                id="logo"/>
                        </subviews>

                        <constraints>
                            <!-- Center Logo -->
                            <constraint firstItem="logo" firstAttribute="centerX"
                                secondItem="mainView" secondAttribute="centerX" id="c1"/>
                            <constraint firstItem="logo" firstAttribute="centerY"
                                secondItem="mainView" secondAttribute="centerY" id="c2"/>

                            <!-- Optional size -->
                            <constraint firstItem="logo" firstAttribute="width"
                                constant="150" id="c3"/>
                            <constraint firstItem="logo" firstAttribute="height"
                                constant="150" id="c4"/>
                        </constraints>

                    </view>
                </viewController>

                <placeholder placeholderIdentifier="IBFirstResponder"
                    id="firstResponder" sceneMemberID="firstResponder"/>

            </objects>
        </scene>
    </scenes>

    <resources>
        <image name="LaunchImage" width="150" height="150"/>
    </resources>

</document>